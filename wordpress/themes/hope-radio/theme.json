{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,

  "settings": {

    "color": {
      "custom": false,
      "defaultPalette": false,
      "defaultGradients": false,
      "customGradient": false,
      "palette": [
        { "name": "Primaire",   "slug": "primary",   "color": "#72004A" },
        { "name": "Secondaire", "slug": "secondary",  "color": "#E35711" },
        { "name": "Tertiaire",  "slug": "tertiary",   "color": "#2847AF" },
        { "name": "Blanc",      "slug": "white",      "color": "#FFFFFF" },
        { "name": "Noir",       "slug": "black",      "color": "#000000" }
      ]
    },

    "typography": {
      "customFontSize": false,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "name": "Century Gothic",
          "slug": "century-gothic",
          "fontFamily": "'Century Gothic', 'AppleGothic', 'Trebuchet MS', sans-serif"
        },
        {
          "name": "Gravesend Sans",
          "slug": "gravesend-sans",
          "fontFamily": "'Gravesend Sans', sans-serif"
        },
        {
          "name": "Copyright Radoslaw Lukasiewicz",
          "slug": "radluka",
          "fontFamily": "'Copyright Radoslaw Lukasiewicz', sans-serif"
        }
      ],
      "fontSizes": [
        { "name": "H1", "slug": "h1", "size": "120px" },
        { "name": "H2", "slug": "h2", "size": "88px"  },
        { "name": "H3", "slug": "h3", "size": "64px"  },
        { "name": "H4", "slug": "h4", "size": "48px"  },
        { "name": "H5", "slug": "h5", "size": "32px"  },
        { "name": "Corps", "slug": "body", "size": "16px" }
      ]
    },

    "spacing": {
      "customSpacingSize": false,
      "defaultSpacingSizes": false,
      "units": ["px", "rem", "%"]
    },

    "border": {
      "color": false,
      "radius": false,
      "style": false,
      "width": false
    },

    "shadow": {
      "defaultPresets": false,
      "presets": []
    },

    "layout": {
      "contentSize": "1200px",
      "wideSize": "1440px"
    },

    "useRootPaddingAwareAlignments": true,

    "blocks": {
      "core/button": {
        "border": {
          "radius": true
        }
      }
    }
  },

  "styles": {

    "color": {
      "background": "#FFFFFF",
      "text": "#000000"
    },

    "typography": {
      "fontFamily": "var(--wp--preset--font-family--century-gothic)",
      "fontSize": "var(--wp--preset--font-size--body)",
      "lineHeight": "1.8"
    },

    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--gravesend-sans)",
          "fontSize": "var(--wp--preset--font-size--h1)",
          "fontWeight": "700",
          "lineHeight": "1.1"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--gravesend-sans)",
          "fontSize": "var(--wp--preset--font-size--h2)",
          "fontWeight": "700",
          "lineHeight": "1.1"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--gravesend-sans)",
          "fontSize": "var(--wp--preset--font-size--h3)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--gravesend-sans)",
          "fontSize": "var(--wp--preset--font-size--h4)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--gravesend-sans)",
          "fontSize": "var(--wp--preset--font-size--h5)",
          "fontWeight": "700",
          "lineHeight": "1.3"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--body)",
          "fontWeight": "600"
        },
        "spacing": {
          "padding": {
            "top": "10px",
            "bottom": "10px",
            "left": "30px",
            "right": "30px"
          }
        },
        "border": {
          "radius": "9999px"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      }
    },

    "blocks": {
      "core/separator": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        "border": {
          "color": "var(--wp--preset--color--primary)",
          "width": "1px"
        }
      }
    }
  },

  "customTemplates": [],

  "templateParts": []
}
