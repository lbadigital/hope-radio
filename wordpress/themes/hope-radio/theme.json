{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,

  "settings": {

    "color": {
      "custom": false,
      "defaultPalette": false,
      "defaultGradients": false,
      "customGradient": false,
      "palette": [
        { "name": "Orange principal",   "slug": "orange-principal",   "color": "#E45612" },
        { "name": "Violet principal",   "slug": "violet-principal",   "color": "#720049" },
        { "name": "Jaune secondaire",   "slug": "jaune-secondaire",   "color": "#EEBB72" },
        { "name": "Violet secondaire",  "slug": "violet-secondaire",  "color": "#320C52" },
        { "name": "Rouge secondaire",   "slug": "rouge-secondaire",   "color": "#320C52" },
        { "name": "Rose secondaire",    "slug": "rose-secondaire",    "color": "#B929D8" },
        { "name": "Blanc",              "slug": "blanc",              "color": "#FFFFFF" },
        { "name": "Noir",               "slug": "noir",               "color": "#212320" }
      ]
    },

    "typography": {
      "customFontSize": false,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "name": "Century Gothic",
          "slug": "century-gothic",
          "fontFamily": "'Century Gothic', 'AppleGothic', 'Trebuchet MS', sans-serif"
        },
        {
          "name": "Gravesend Sans",
          "slug": "gravesend-sans",
          "fontFamily": "'Gravesend Sans', sans-serif"
        },
        {
          "name": "Copyright Radoslaw Lukasiewicz",
          "slug": "radluka",
          "fontFamily": "'Copyright Radoslaw Lukasiewicz', sans-serif"
        }
      ],
      "fontSizes": [
        { "name": "HUGE",               "slug": "huge",               "size": "120px" },
        { "name": "H1",                 "slug": "h1",                 "size": "88px"  },
        { "name": "H2",                 "slug": "h2",                 "size": "88px"  },
        { "name": "H3",                 "slug": "h3",                 "size": "64px"  },
        { "name": "H4",                 "slug": "h4",                 "size": "48px"  },
        { "name": "H5",                 "slug": "h5",                 "size": "28px"  },
        { "name": "BIG",                "slug": "big",                "size": "56px"  },
        { "name": "Sous-titre",         "slug": "sous-titre",         "size": "32px"  },
        { "name": "Paragraphe large",   "slug": "paragraphe-large",   "size": "24px"  },
        { "name": "Paragraphe Medium",  "slug": "paragraphe-medium",  "size": "18px"  },
        { "name": "Paragraphe Regular", "slug": "paragraphe-regular", "size": "16px"  },
        { "name": "Small text LABEL",   "slug": "small-label",        "size": "14px"  },
        { "name": "X-small text label", "slug": "xsmall-label",       "size": "12px"  },
        { "name": "X-small text TAG",   "slug": "xsmall-tag",         "size": "10px"  },
        { "name": "Petit titre",        "slug": "petit-titre",        "size": "20px"  },
        { "name": "Titre GRAPHIQUE",    "slug": "titre-graphique",    "size": "55px"  },
        { "name": "Text Bouton",        "slug": "text-bouton",        "size": "16px"  },
        { "name": "Small texte",        "slug": "small-texte",        "size": "14px"  },
        { "name": "Text mobile",        "slug": "text-mobile",        "size": "12px"  }
      ]
    },

    "spacing": {
      "customSpacingSize": false,
      "defaultSpacingSizes": false,
      "units": ["px", "rem", "%"]
    },

    "border": {
      "color": false,
      "radius": false,
      "style": false,
      "width": false
    },

    "shadow": {
      "defaultPresets": false,
      "presets": []
    },

    "layout": {
      "contentSize": "1200px",
      "wideSize": "1440px"
    },

    "useRootPaddingAwareAlignments": true,

    "blocks": {
      "core/button": {
        "border": {
          "radius": true
        }
      }
    }
  },

  "styles": {

    "color": {
      "background": "#FFFFFF",
      "text": "#212320"
    },

    "typography": {
      "fontFamily": "var(--wp--preset--font-family--century-gothic)",
      "fontSize": "var(--wp--preset--font-size--paragraphe-regular)",
      "lineHeight": "1.8"
    },

    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--gravesend-sans)",
          "fontSize": "var(--wp--preset--font-size--h1)",
          "fontWeight": "700",
          "lineHeight": "0.9"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--gravesend-sans)",
          "fontSize": "var(--wp--preset--font-size--h2)",
          "fontWeight": "700",
          "lineHeight": "0.9"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--gravesend-sans)",
          "fontSize": "var(--wp--preset--font-size--h3)",
          "fontWeight": "700",
          "lineHeight": "0.9"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--gravesend-sans)",
          "fontSize": "var(--wp--preset--font-size--h4)",
          "fontWeight": "700",
          "lineHeight": "0.83"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--gravesend-sans)",
          "fontSize": "var(--wp--preset--font-size--h5)",
          "fontWeight": "700",
          "lineHeight": "1.1"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--violet-principal)",
          "text": "var(--wp--preset--color--blanc)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--century-gothic)",
          "fontSize": "var(--wp--preset--font-size--text-bouton)",
          "fontWeight": "600",
          "lineHeight": "normal"
        },
        "spacing": {
          "padding": {
            "top": "10px",
            "bottom": "10px",
            "left": "30px",
            "right": "30px"
          }
        },
        "border": {
          "radius": "9999px"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--violet-principal)"
        }
      }
    },

    "blocks": {
      "core/separator": {
        "color": {
          "text": "var(--wp--preset--color--violet-principal)"
        },
        "border": {
          "color": "var(--wp--preset--color--violet-principal)",
          "width": "1px"
        }
      }
    }
  },

  "customTemplates": [],

  "templateParts": []
}